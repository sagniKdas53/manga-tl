# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_DB=manga_library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ==============================================================================
# MinIO Configuration
# ==============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# ==============================================================================
# Security & JWT Tokens
# ==============================================================================
JWT_SECRET=
INTERNAL_API_TOKEN=

# ==============================================================================
# Traefik & Routing Configuration
# ==============================================================================
HOSTNAME=
CONTEXT_PATH=/tlhub

# ==============================================================================
# Translation Pipeline Configuration
# ==============================================================================

# 1. Cloud AI Model Config (Step 1)
# Supported providers: openrouter, openai, anthropic, gemini, nvidia
# If you use multiple providers, you can set their specific keys below.

# Fallback/Default Key (used if a provider-specific key is missing)
API_KEY=

# Provider-Specific Keys
OPENROUTER_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ==============================================================================
# Model Configuration (Unified worker singleton settings)
# ==============================================================================

# 1. OCR Model Configuration (To use cloud OCR set DISABLE_LOCAL_OCR to true)
OCR_MODEL_PROVIDER=openrouter
OCR_VLM_MODEL=google/gemini-3.5-flash
# Fallback list for OCR (Active model at index 0)
OCR_VLM_MODEL_LIST=qwen/qwen3-vl-8b-instruct,google/gemini-3.5-flash,ollama/qwen2.5-vl-3b-instruct

# 2. Translation (TL) Model Configuration
TL_MODEL_PROVIDER=openrouter
TL_LLM_MODEL=google/gemini-3.5-flash
# Fallback list for Translation
TL_LLM_MODEL_LIST=deepseek/deepseek-v4-pro,google/gemini-3.5-flash,ollama/gemma4:e4b

# 3. Quality Assurance (QA) Model Configuration
QA_MODEL_PROVIDER=openrouter
QA_LLM_MODEL=google/gemini-3.5-flash
QA_LLM_MODEL_LIST=deepseek/deepseek-v4-flash,google/gemini-3.5-flash,ollama/gemma4:e4b
QA_VLM_MODEL=google/gemini-3.5-flash
QA_VLM_MODEL_LIST=google/gemini-3.1-flash-lite,google/gemini-3.5-flash,ollama/qwen2.5-vl-3b-instruct

# 2. Local AI Model Config (Step 2)
# Supported local providers: lmstudio, ollama
# When MODEL_PROVIDER is set to 'ollama' or 'lmstudio', ALL cloud AI tiers
# are skipped — only the local model is used (local-only mode).
# Endpoint for local model (leave blank to auto-detect based on provider):
#   - ollama   -> http://ollama:11434/v1/chat/completions  (Docker service)
#   - lmstudio -> http://host.docker.internal:1234/v1/chat/completions (host)
LOCAL_LLM_PROVIDER=lmstudio
LOCAL_LLM_ENDPOINT=http://host.docker.internal:1234/v1/chat/completions
LOCAL_LLM_MODEL=
LOCAL_VLM_MODEL=
DISABLE_LOCAL_LLM=false

# 2.5 Cloud & Local OCR
DISABLE_LOCAL_OCR=false
PADDLEOCR_DET_MODEL=PP-OCRv6_medium_det
PADDLEOCR_REC_MODEL=PP-OCRv6_medium_rec
PADDLEOCR_DEVICE=cpu

# 3. DeepL Fallback Config (Step 3)
# Set your DeepL API key here. Both Free and Pro keys are supported.
DISABLE_DEEPL_TRANSLATE=false
DEEPL_API_KEY=

# 3.5. Google Translate Config
DISABLE_GOOGLE_TRANSLATE=false

# 4. Rate Limiting
# Rate limit for translation requests. E.g. "60" (60 RPM) or "5/s" (5 requests per second)
# Leave blank for no rate limiting.
RATE_LIMIT=60

# 5. Concurrency
# Max concurrent jobs running on the worker
CONCURRENT_JOBS=2
