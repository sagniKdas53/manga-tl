# Translation Pipeline Configuration

# 1. Cloud AI Model Config (Step 1)
# Supported providers: openrouter, openai, anthropic, gemini, nvidia
# If API_KEY is provided, the worker will use this provider first.
MODEL_PROVIDER=openrouter
API_KEY=

# Model name (defaults will be used if left blank)
# Examples: meta-llama/llama-3-8b-instruct:free (OpenRouter), gpt-4o-mini (OpenAI), gemini-1.5-flash (Gemini)
PREFERRED_MODEL=

# 2. Local AI Model Config (Step 2)
# Supported local providers: lmstudio, ollama
# Endpoint for local model (leave blank to auto-detect based on provider)
# In Docker, host.docker.internal refers to the host machine.
LOCAL_LLM_PROVIDER=lmstudio
LOCAL_LLM_ENDPOINT=http://host.docker.internal:1234/v1/chat/completions

# 3. DeepL Fallback Config (Step 3)
# Set your DeepL API key here. Both Free and Pro keys are supported.
DEEPL_API_KEY=

# 4. Rate Limiting
# Rate limit for translation requests. E.g. "60" (60 RPM) or "5/s" (5 requests per second)
# Leave blank for no rate limiting.
RATE_LIMIT=60
