# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_DB=manga_library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ==============================================================================
# MinIO Configuration
# ==============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# ==============================================================================
# Security & JWT Tokens
# ==============================================================================
JWT_SECRET=
INTERNAL_API_TOKEN=

# ==============================================================================
# Traefik & Routing Configuration
# ==============================================================================
HOSTNAME=
CONTEXT_PATH=/tlhub
LOG_LEVEL=INFO
LOG_LEVEL_WORKER=DEBUG

# ==============================================================================
# Cloud AI Provider Keys
# ==============================================================================
# Fallback/Default Key (used if a provider-specific key is missing)
API_KEY=

# Provider-Specific Keys
OPENROUTER_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ==============================================================================
# Model Configuration (Unified worker singleton settings)
# ==============================================================================

# 1. OCR Model Configuration (To use cloud OCR set DISABLE_LOCAL_OCR to true)
OCR_MODEL_PROVIDER=openrouter
OCR_VLM_MODEL=qwen/qwen3-vl-32b-instruct
# Fallback list for OCR (Active model at index 0, followed by fallback models)
OCR_VLM_MODEL_LIST=qwen/qwen3-vl-32b-instruct,google/gemini-3.5-flash,google/gemini-2.5-flash,google/gemini-3.1-flash-lite

# 2. Translation (TL) Model Configuration
TL_MODEL_PROVIDER=openrouter
TL_LLM_MODEL=deepseek/deepseek-v4-pro
# Fallback list for Translation (Active model at index 0, followed by fallback models)
TL_LLM_MODEL_LIST=deepseek/deepseek-v4-pro,deepseek/deepseek-v4-flash,google/gemini-3.5-flash,google/gemini-2.5-flash

# 3. Quality Assurance (QA) Model Configuration
QA_MODEL_PROVIDER=openrouter
QA_LLM_MODEL=deepseek/deepseek-v4-flash
# Fallback list for QA LLM
QA_LLM_MODEL_LIST=deepseek/deepseek-v4-flash,deepseek/deepseek-v4-pro,google/gemini-3.5-flash,google/gemini-2.5-flash,openai/gpt-oss-20b:free
QA_VLM_MODEL=google/gemini-3.1-flash-lite
# Fallback list for QA VLM
QA_VLM_MODEL_LIST=google/gemini-3.1-flash-lite,google/gemini-3.5-flash,google/gemini-2.5-flash

# ==============================================================================
# Local AI Model Configuration (Step 2 Fallback)
# ==============================================================================
# Supported local providers: lmstudio, ollama
# Endpoint for local model (leave blank to auto-detect based on provider):
#   - ollama   -> http://ollama:11434/v1/chat/completions
#   - lmstudio -> http://host.docker.internal:1234/v1/chat/completions
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_ENDPOINT=http://ollama:11434/v1/chat/completions
LOCAL_LLM_MODEL=gemma4:e4b
LOCAL_VLM_MODEL=qwen2.5-vl-3b-instruct
DISABLE_LOCAL_LLM=true

# ==============================================================================
# Local & Cloud OCR Configurations
# ==============================================================================
# Set this to false to use local PP-models
DISABLE_LOCAL_OCR=false
PADDLEOCR_DET_MODEL=PP-OCRv6_medium_det
PADDLEOCR_REC_MODEL=PP-OCRv6_medium_rec
PADDLEOCR_DEVICE=cpu

# ==============================================================================
# Fallback Engines (DeepL & Google Translate)
# ==============================================================================
DISABLE_DEEPL_TRANSLATE=true
DEEPL_API_KEY=
DISABLE_GOOGLE_TRANSLATE=true

# ==============================================================================
# Performance & Service Configurations
# ==============================================================================
# Rate limit for translation requests. E.g. "60" (60 RPM) or "10" (10 RPM)
RATE_LIMIT=10
REGISTRY_OWNER=sagnikdas53
USE_REMOTE_ML=false
REMOTE_ML_URL=http://worker:8000
QA_MODE=auto

# Concurrency
# How many pages should be processed simultaneously
CONCURRENT_JOBS=2

# When true (default), light jobs can use idle heavy slots for extra throughput.
REUSE_IDLE_SLOTS=true
