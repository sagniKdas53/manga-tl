# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_DB=manga_library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ==============================================================================
# MinIO Configuration
# ==============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# ==============================================================================
# Security & JWT Tokens
# ==============================================================================
JWT_SECRET=
INTERNAL_API_TOKEN=

# ==============================================================================
# Traefik & Routing Configuration
# ==============================================================================
HOSTNAME=
CONTEXT_PATH=/tlhub

# ==============================================================================
# Translation Pipeline Configuration
# ==============================================================================

# 1. Cloud AI Model Config (Step 1)
# Supported providers: openrouter, openai, anthropic, gemini, nvidia
# If you use multiple providers, you can set their specific keys below.
# The worker will automatically pick the right key based on MODEL_PROVIDER.
MODEL_PROVIDER=openrouter

# Fallback/Default Key (used if a provider-specific key is missing)
API_KEY=

# Provider-Specific Keys
OPENROUTER_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model name (defaults will be used if left blank)
# Examples: meta-llama/llama-3-8b-instruct:free (OpenRouter), gpt-4o-mini (OpenAI), google/gemini-3.5-flash (Gemini)
PREFERRED_LLM_MODEL=deepseek/deepseek-v4-pro
PREFERRED_VLM_MODEL=google/gemini-3.5-flash

# 1.5. QA Provider Override (Optional)
# If you want to use a different provider/model specifically for QA (e.g. Gemini for translation, Nvidia for QA),
# you can set QA_MODEL_PROVIDER, QA_LLM_MODEL, and QA_VLM_MODEL here. If left blank, it defaults to MODEL_PROVIDER.
QA_MODEL_PROVIDER=openrouter
QA_LLM_MODEL=deepseek/deepseek-v4-flash
QA_VLM_MODEL=google/gemini-3.1-flash-lite

# 2. Local AI Model Config (Step 2)
# Supported local providers: lmstudio, ollama
# When MODEL_PROVIDER is set to 'ollama' or 'lmstudio', ALL cloud AI tiers
# are skipped — only the local model is used (local-only mode).
# Endpoint for local model (leave blank to auto-detect based on provider):
#   - ollama   -> http://ollama:11434/v1/chat/completions  (Docker service)
#   - lmstudio -> http://host.docker.internal:1234/v1/chat/completions (host)
LOCAL_LLM_PROVIDER=lmstudio
LOCAL_LLM_ENDPOINT=http://host.docker.internal:1234/v1/chat/completions
LOCAL_LLM_MODEL=
LOCAL_VLM_MODEL=
DISABLE_LOCAL_LLM=false

# 2.5 Cloud OCR
DISABLE_LOCAL_OCR=false

# 3. DeepL Fallback Config (Step 3)
# Set your DeepL API key here. Both Free and Pro keys are supported.
DISABLE_DEEPL_TRANSLATE=false
DEEPL_API_KEY=

# 3.5. Google Translate Config
DISABLE_GOOGLE_TRANSLATE=false

# 4. Rate Limiting
# Rate limit for translation requests. E.g. "60" (60 RPM) or "5/s" (5 requests per second)
# Leave blank for no rate limiting.
RATE_LIMIT=60
